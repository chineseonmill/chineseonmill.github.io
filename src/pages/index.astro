---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout>
  <HeroSection 
    title="Welcome to Our Church"
    subtitle="A place of worship, community, and spiritual growth"
    backgroundImage="/uploads/hero-bg.webp"
    ctaText="Plan Your Visit"
    ctaLink="/im-new"
    secondaryCtaText="Watch Sermons"
    secondaryCtaLink="/sermons"
  />
  
  <!-- Service Times -->
  <section class="py-16 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Join Us This Sunday</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-1 gap-8 mb-8">
          <div class="bg-gray-50 p-8 rounded-lg shadow-sm">
            <h3 class="text-xl font-bold mb-3">Morning Service</h3>
            <p class="text-2xl font-bold text-primary-600 mb-2">9:30 AM</p>
            <p class="text-gray-600 mb-4">1300 S Mill Ave, Tempe</p>
            <p class="italic text-gray-500">In-person</p>
          </div>
        </div>
        
        <Button href="/im-new" variant="outline">
          Plan Your Visit
        </Button>
      </div>
    </div>
  </section>
  
  <!-- About Section -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <img 
            src="/uploads/church-default.webp" 
            alt="Our Church" 
            class="rounded-lg shadow-lg object-cover w-full h-full"
          />
        </div>
        
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">About Our Church</h2>
          <p class="text-gray-700 mb-6 text-lg">
            We are a welcoming Christian community dedicated to sharing God's love through worship, fellowship, and service. Our church has been serving the community for over 50 years, providing a place for spiritual growth and connection.
          </p>
          <p class="text-gray-700 mb-8 text-lg">
            Whether you're exploring faith for the first time or looking for a church home, we invite you to join us. Our diverse congregation welcomes people of all ages, backgrounds, and walks of life.
          </p>
          
          <Button href="/about-us">
            Learn More About Us
          </Button>
        </div>
      </div>
    </div>
  </section>
  
  
  <!-- Call to Action -->
  <section 
    class="py-20 bg-cover bg-center text-white"
    style="background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(/uploads/thank-you-bg.webp)"
  >
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">Ready to Join Our Community?</h2>
        <p class="text-xl mb-8">
          We'd love to welcome you to our church family. Come visit us this Sunday or reach out with any questions.
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <Button href="/im-new" variant="primary" size="lg">
            I'm New Here
          </Button>
          
          <Button href="/contact" variant="outline" size="lg" class="bg-white/10 text-white border-white hover:bg-white hover:text-gray-900 backdrop-blur-sm">
            Contact Us
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>